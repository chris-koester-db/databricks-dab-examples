{
  "datasets": [
    {
      "name": "b1c884db",
      "displayName": "param_warehouses",
      "queryLines": [
        " select distinct warehouse_name as `Warehouse Name`\n",
        " from dim_warehouse\n",
        " \n",
        " union all\n",
        " \n",
        " select 'All' as `Warehouse Name`"
      ],
      "catalog": "users",
      "schema": "chris_koester"
    },
    {
      "name": "2d419c4e",
      "displayName": "query_duration_pct",
      "queryLines": [
        "-- Grouping sets allows for filtering by warehouse name or for all warehouses with a single select\n",
        "select\n",
        "  date as Date,\n",
        "  coalesce(`Warehouse Name`, 'All') as `Warehouse Name`,\n",
        "  measure(`Query Duration Sec P50`) as `Query Duration Sec P50`,\n",
        "  measure(`Query Duration Sec P90`) as `Query Duration Sec P90`,\n",
        "  measure(`Query Duration Sec P95`) as `Query Duration Sec P95`\n",
        "from\n",
        "  metv_query_history\n",
        "where\n",
        "  date between :param_date.min and :param_date.max\n",
        "group by\n",
        "  grouping sets((date), (date, `Warehouse Name`))\n",
        "having\n",
        "  coalesce(`Warehouse Name`, 'All') = :warehouse_name"
      ],
      "parameters": [
        {
          "displayName": "param_date",
          "keyword": "param_date",
          "dataType": "DATE",
          "complexType": "RANGE",
          "defaultSelection": {
            "range": {
              "dataType": "DATE",
              "min": {
                "value": "now-90d/d"
              },
              "max": {
                "value": "now/d"
              }
            }
          }
        },
        {
          "displayName": "warehouse_name",
          "keyword": "warehouse_name",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        }
      ],
      "catalog": "users",
      "schema": "chris_koester"
    },
    {
      "name": "a15dfc79",
      "displayName": "dbsql_usage",
      "queryLines": [
        "-- Grouping sets allows for filtering by warehouse name or for all warehouses with a single select\n",
        "-- Selecting 'All' returns all individual warehouse rows for visualizing in a stacked bar chart\n",
        "-- Selecting an individual warehouse returns only rows for that warehouse\n",
        "select\n",
        "  date as Date,\n",
        "  coalesce(`Warehouse Name`, 'All') as `Warehouse Name`,\n",
        "  measure(`Usage Sum`) as `Usage Sum`\n",
        "from metv_usage\n",
        "where\n",
        "  date between :param_date.min and :param_date.max\n",
        "group by\n",
        "  grouping sets((date), (date, `Warehouse Name`))\n",
        "having\n",
        "  (\n",
        "    :warehouse_name = 'All'\n",
        "    AND `Warehouse Name` != 'All'\n",
        "  )\n",
        "  OR (\n",
        "    :warehouse_name != 'All'\n",
        "    AND `Warehouse Name` = :warehouse_name\n",
        "  )"
      ],
      "parameters": [
        {
          "displayName": "warehouse_name",
          "keyword": "warehouse_name",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        },
        {
          "displayName": "param_date",
          "keyword": "param_date",
          "dataType": "DATE",
          "complexType": "RANGE",
          "defaultSelection": {
            "range": {
              "dataType": "DATE",
              "min": {
                "value": "now-90d/d"
              },
              "max": {
                "value": "now/d"
              }
            }
          }
        }
      ],
      "catalog": "users",
      "schema": "chris_koester"
    }
  ],
